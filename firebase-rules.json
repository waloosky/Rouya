{
  "rules": {
    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && ((auth.uid === $uid && !data.exists()) || root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['displayName', 'email', 'role', 'status', 'createdAt'])",
        "displayName": { ".validate": "newData.isString() && newData.val().length >= 2" },
        "email": { ".validate": "newData.isString() && newData.val().length > 3" },
        "role": { ".validate": "newData.val() === 'student' || newData.val() === 'teacher' || newData.val() === 'admin'" },
        "status": { ".validate": "newData.val() === 'pending' || newData.val() === 'active' || newData.val() === 'blocked'" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "grade": { ".validate": "newData.val() === null || newData.isString()" },
        "$other": { ".validate": false }
      }
    },
    "lessons": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'active'",
      "$lessonId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['title', 'subject', 'createdAt'])",
        "title": { ".validate": "newData.isString() && newData.val().length > 0" },
        "subject": { ".validate": "newData.isString() && newData.val().length > 0" },
        "createdAt": { ".validate": "newData.isNumber()" }
      }
    },
    "progress": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "$lessonId": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['view_count']) && newData.child('view_count').isNumber() && newData.child('view_count').val() >= 0 && newData.child('view_count').val() <= 10",
          "view_count": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "lastView": { ".validate": "newData.isNumber()" },
          "score": {
            ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
          }
        }
      }
    },
    "exam_results": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "$lessonId": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['score', 'total', 'submittedAt'])",
          "score": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "total": { ".validate": "newData.isNumber() && newData.val() > 0" },
          "submittedAt": { ".validate": "newData.isNumber()" },
          "lessonId": { ".validate": "newData.isString() || !newData.exists()" },
          "teacherUid": { ".validate": "newData.isString() || !newData.exists()" },
          "studentName": { ".validate": "newData.isString() || !newData.exists()" }
        }
      }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "lastSeen": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChild('ts') && newData.child('ts').isNumber()"
        },
        "items": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          "$notifId": {
            ".validate": "newData.hasChildren(['title', 'body', 'ts'])",
            "title": { ".validate": "newData.isString() && newData.val().length > 0" },
            "body": { ".validate": "newData.isString() && newData.val().length > 0" },
            "ts": { ".validate": "newData.isNumber()" },
            "icon": { ".validate": "newData.isString() || !newData.exists()" }
          }
        }
      }
    },
    "leaderboard": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'active'",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'teacher' || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "settings": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
